# Backend environment variables
# Copy this file to .env and fill in your values

# OpenAI API key — required for the /api/chat endpoint
OPENAI_API_KEY=sk-...

# Optional: override the default port (3001)
# PORT=3001

# Optional: restrict CORS to your frontend origin in production
# FRONTEND_ORIGIN=https://yourdomain.com

# Optional: custom OpenAI-compatible base URL (e.g. Azure, local Ollama)
# OPENAI_BASE_URL=https://...
